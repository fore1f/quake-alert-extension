{
  "manifest_version": 3,
  "name": "QuakeAlert",
  "version": "1.2.0",
  "description": "最新の地震情報と緊急地震速報（EEW）をデスクトップ通知とポップアップで表示します。",
  "permissions": [
    "alarms",
    "notifications",
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://api.p2pquake.net/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/app_icon_16.png",
      "48": "icons/app_icon_48.png",
      "128": "icons/app_icon_128.png"
    }
  },
  "icons": {
    "16": "icons/app_icon_16.png",
    "48": "icons/app_icon_48.png",
    "128": "icons/app_icon_128.png"
  },
  "background": {
    "service_worker": "worker.js"
  }
}
